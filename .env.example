# ── 필수 (프로덕션) ─────────────────────────────────────────────
# 세션 JWT 서명 키 — 미설정 시 프로덕션에서 기동 불가. openssl rand -hex 32 로 생성.
AUTH_SECRET=

# ── 선택 — 미설정 시 데모 모드 ──────────────────────────────────
# OpenDART API 키 (https://opendart.fss.or.kr 무료 발급) — 설정 시 전체 상장사 실데이터
DART_API_KEY=

# Toss Payments v2 키 (https://developers.tosspayments.com) — 미설정 시 데모 결제
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# 배포 도메인 (OG 메타·API 예시 URL 에 사용). 예: https://gongsiradar.example.com
NEXT_PUBLIC_APP_URL=
